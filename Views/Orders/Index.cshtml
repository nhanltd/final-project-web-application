@model OrderManagementSystem.Models.OrdersViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Management System</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <!-- Stylesheet -->
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <div class="container">
        <!-- Header -->
        <header class="app-header">
            <h1>Order Management System</h1>
           
        </header>

        <!-- Notification Alerts -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success" style="padding: 10px 15px; background-color: #d1e7dd; border: 1px solid #badbcc; color: #0f5132; margin-bottom: 20px; border-radius: 4px; font-size: 0.9rem;">
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger" style="padding: 10px 15px; background-color: #f8d7da; border: 1px solid #f5c2c7; color: #842029; margin-bottom: 20px; border-radius: 4px; font-size: 0.9rem;">
                @TempData["ErrorMessage"]
            </div>
        }

        <!-- Overview Statistics Section -->
        <section class="summary-section">
            <a href="/Orders" class="summary-box" style="text-decoration: none; color: inherit;">
                <span class="summary-title">Total Orders</span>
                <strong>@Model.TotalOrders</strong>
            </a>
            <a href="/Orders?highlightLinqKey=revenue" class="summary-box" style="text-decoration: none; color: inherit;">
                <span class="summary-title">Total Revenue (Completed)</span>
                <strong class="text-success">@Model.TotalRevenue.ToString("N0") ₫</strong>
            </a>
            <a href="/Orders?highlightLinqKey=statistics" class="summary-box" style="text-decoration: none; color: inherit;">
                <span class="summary-title">Status Breakdown (GroupBy)</span>
                <div class="status-summary-list">
                    <span class="status-summary-item">Pending: @Model.StatusStats["Pending"]</span>
                    <span class="status-summary-item">Processing: @Model.StatusStats["Processing"]</span>
                    <span class="status-summary-item">Completed: @Model.StatusStats["Completed"]</span>
                    <span class="status-summary-item">Cancelled: @Model.StatusStats["Cancelled"]</span>
                </div>
            </a>
        </section>

        <!-- Main Workspace (Grid Layout) -->
        <div class="main-layout">
            <!-- Left Column: Orders List Table -->
            <div class="content-card">
                <div class="card-header">
                    <h2>Order List</h2>
                    <button class="btn btn-success" id="btn-open-create-modal">
                        + Create New Order
                    </button>
                </div>

                <!-- Search and Filters Form -->
                <div class="filter-bar">
                    <form method="get" action="/Orders" style="display: flex; flex-wrap: wrap; gap: 10px; align-items: center; width: 100%;">
                        <div class="form-group-inline" style="flex: 2; min-width: 180px;">
                            <input type="text" name="searchString" value="@Model.SearchString" placeholder="Search by customer name...">
                        </div>
                        <div class="form-group-inline" style="flex: 1; min-width: 150px;">
                            <select name="statusFilter" onchange="this.form.submit()">
                                <option value="">-- All Statuses --</option>
                                <option value="Pending" selected="@(Model.StatusFilter == "Pending" ? "selected" : null)">Pending</option>
                                <option value="Processing" selected="@(Model.StatusFilter == "Processing" ? "selected" : null)">Processing</option>
                                <option value="Completed" selected="@(Model.StatusFilter == "Completed" ? "selected" : null)">Completed</option>
                                <option value="Cancelled" selected="@(Model.StatusFilter == "Cancelled" ? "selected" : null)">Cancelled</option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary">Search</button>
                        
                        @if (Model.ShowTop5)
                        {
                            <a href="/Orders" class="btn btn-primary active">Clear Top 5</a>
                        }
                        else
                        {
                            <a href="/Orders?showTop5=true" class="btn btn-primary">Top 5 Orders</a>
                        }
                        
                        <a href="/Orders" class="btn btn-secondary">Reset</a>
                    </form>
                </div>

                <!-- Orders Table -->
                <div class="table-responsive">
                    <table class="orders-table">
                        <thead>
                            <tr>
                                <th style="width: 80px;">Order ID</th>
                                <th>Customer</th>
                                <th>Order Date</th>
                                <th>Total Amount</th>
                                <th>Status</th>
                                <th style="width: 250px; text-align: center;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Orders.Count == 0)
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-5">No orders found.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var order in Model.Orders)
                                {
                                    <tr>
                                        <td><span class="order-id-badge">#@order.Id</span></td>
                                        <td>
                                            <div class="customer-name-cell">@order.CustomerName</div>
                                            <div style="font-size: 0.75rem; color: var(--text-secondary);">Customer ID: #@order.CustomerId</div>
                                        </td>
                                        <td>
                                            <div>@order.OrderDate.ToLocalTime().ToString("MM/dd/yyyy")</div>
                                            <div style="font-size: 0.75rem; color: var(--text-secondary);">@order.OrderDate.ToLocalTime().ToString("hh:mm tt")</div>
                                        </td>
                                        <td><span class="order-amount-cell">@order.TotalAmount.ToString("N0") ₫</span></td>
                                        <td>
                                            <span class="badge badge-@order.Status.ToLower()">@order.Status</span>
                                        </td>
                                        <td>
                                            <div class="status-actions-cell">
                                                <!-- Change Status Form POST -->
                                                <form method="post" action="/Orders/UpdateStatus" style="display:inline;">
                                                    <input type="hidden" name="id" value="@order.Id" />
                                                    <select name="status" onchange="this.form.submit()" class="btn-status-change" style="padding: 4px 6px; font-size: 0.8rem;">
                                                        <option value="Pending" selected="@(order.Status == "Pending" ? "selected" : null)">Pending</option>
                                                        <option value="Processing" selected="@(order.Status == "Processing" ? "selected" : null)">Processing</option>
                                                        <option value="Completed" selected="@(order.Status == "Completed" ? "selected" : null)">Completed</option>
                                                        <option value="Cancelled" selected="@(order.Status == "Cancelled" ? "selected" : null)">Cancelled</option>
                                                    </select>
                                                </form>

                                                <!-- Delete Order Form POST -->
                                                <form method="post" action="/Orders/Delete" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete order #@order.Id?')">
                                                    <input type="hidden" name="id" value="@order.Id" />
                                                    <button type="submit" class="btn btn-danger" style="padding: 4px 8px; font-size: 0.8rem;">Delete</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
                
                <div class="card-footer" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px;">
                    <span>Showing: @Model.Orders.Count order(s)</span>
                    @if (!Model.ShowTop5 && Model.TotalPages > 1)
                    {
                        <div class="pagination-buttons" style="display: flex; gap: 8px; align-items: center;">
                            @if (Model.HasPreviousPage)
                            {
                                <a href="/Orders?pageNumber=@(Model.CurrentPage - 1)&searchString=@Model.SearchString&statusFilter=@Model.StatusFilter" class="btn btn-secondary" style="padding: 4px 10px; font-size: 0.85rem; text-decoration: none; display: inline-block;">&laquo; Previous</a>
                            }
                            else
                            {
                                <span class="btn btn-secondary disabled" style="padding: 4px 10px; font-size: 0.85rem; opacity: 0.5; pointer-events: none; display: inline-block;">&laquo; Previous</span>
                            }

                            <span style="font-size: 0.85rem;">Page <strong>@Model.CurrentPage</strong> of @Model.TotalPages</span>

                            @if (Model.HasNextPage)
                            {
                                <a href="/Orders?pageNumber=@(Model.CurrentPage + 1)&searchString=@Model.SearchString&statusFilter=@Model.StatusFilter" class="btn btn-secondary" style="padding: 4px 10px; font-size: 0.85rem; text-decoration: none; display: inline-block;">Next &raquo;</a>
                            }
                            else
                            {
                                <span class="btn btn-secondary disabled" style="padding: 4px 10px; font-size: 0.85rem; opacity: 0.5; pointer-events: none; display: inline-block;">Next &raquo;</span>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Right Column: Active LINQ query display -->
            <div class="linq-card">
                <div class="linq-card-header">
                    <h3>Corresponding LINQ Query</h3>
                </div>
                <div class="linq-card-body">
                    <p class="linq-desc">@Model.ActiveLinqDesc</p>
                    <pre><code>@Model.ActiveLinqCode</code></pre>
                </div>
            </div>
        </div>
    </div>

    <!-- Create Order Modal -->
    <div class="modal-backdrop" id="create-order-modal">
        <div class="modal">
            <div class="modal-header">
                <h3>Create New Order</h3>
                <button class="btn-close" id="btn-close-create-modal">&times;</button>
            </div>
            <form method="post" action="/Orders/Create">
                <div class="modal-body">
                    <div class="form-group">
                        <label for="customer-select">Select Customer <span class="required">*</span></label>
                        <select name="customerId" id="customer-select" required>
                            <option value="" disabled selected>-- Select Customer --</option>
                            @foreach (var c in Model.Customers)
                            {
                                <option value="@c.Id">@c.Name (@c.Email)</option>
                            }
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="order-amount">Total Amount (VNĐ) <span class="required">*</span></label>
                        <input type="number" name="totalAmount" id="order-amount" min="1000" step="1000" placeholder="Enter amount..." required>
                    </div>

                    <div class="form-group">
                        <label for="order-status">Initial Status <span class="required">*</span></label>
                        <select name="status" id="order-status" required>
                            <option value="Pending" selected>Pending</option>
                            <option value="Processing">Processing</option>
                            <option value="Completed">Completed</option>
                            <option value="Cancelled">Cancelled</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" id="btn-cancel-create-modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Save Order</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modal visibility toggle scripts -->
    <script>
        const modal = document.getElementById('create-order-modal');
        const openBtn = document.getElementById('btn-open-create-modal');
        const closeBtn = document.getElementById('btn-close-create-modal');
        const cancelBtn = document.getElementById('btn-cancel-create-modal');

        openBtn.addEventListener('click', () => modal.classList.add('show'));
        
        const closeModal = () => modal.classList.remove('show');
        closeBtn.addEventListener('click', closeModal);
        cancelBtn.addEventListener('click', closeModal);
        modal.addEventListener('click', (e) => {
            if (e.target === modal) closeModal();
        });
    </script>
</body>
</html>
